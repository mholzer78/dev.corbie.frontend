<div class="page">

  <header class="page-header">
    <h1>Color Converterer</h1>
    <p>Convert colors between HEX, RGB, HSL, CMYK and more.</p>
  </header>

  <div class="color-input">
    <input placeholder="#FFD801" />
    <button>Random</button>
    <button>Pick Color</button>
  </div>

  <div class="color-preview bg-yellow-400"></div>

  <section class="value-grid">

    <div class="value-card">
      <div>
        <div class="label">HEX</div>
        <div class="value">#FFD801</div>
      </div>
      <button class="copy-btn">Copy</button>
    </div>

    <div class="value-card">
      <div>
        <div class="label">RGB</div>
        <div class="value">255, 216, 1</div>
      </div>
      <button class="copy-btn">Copy</button>
    </div>

    <div class="value-card">
      <div>
        <div class="label">HSL</div>
        <div class="value">51° 100% 50%</div>
      </div>
      <button class="copy-btn">Copy</button>
    </div>

    <div class="value-card">
      <div>
        <div class="label">CMYK</div>
        <div class="value">0, 15, 100, 0</div>
      </div>
      <button class="copy-btn">Copy</button>
    </div>

  </section>


  <section class="extra-tools">

    <h3>Extra Tools</h3>

    <div class="tool-grid">
      <button class="tool-btn">Contrast Check</button>
      <button class="tool-btn">Copy CSS Var</button>
      <button class="tool-btn">Color Palette</button>
      <button class="tool-btn">Random Color</button>
    </div>

  </section>

</div>